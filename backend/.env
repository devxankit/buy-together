# ── Firebase Realtime Database (chat message store) ─────────────────
# Messages are stored in RTDB; everything else stays in MongoDB.
FIREBASE_DATABASE_URL=https://but-together-default-rtdb.firebaseio.com
# Download from Firebase console: Project Settings → Service accounts →
# "Generate new private key". Save the JSON as backend/serviceAccountKey.json
# (it is gitignored). Then point this at it:
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json
# Alternative for deployment (e.g. Render/Railway): paste the JSON (or its
# base64) into one var instead of shipping a file. JSON wins if both are set.
FIREBASE_SERVICE_ACCOUNT_JSON=

