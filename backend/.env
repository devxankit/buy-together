# ── OTP ─────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
# First {brand} variable in the DLT template below.
OTP_BRAND_NAME=Buy Together
# Must match the registered DLT content template EXACTLY.
# Registered: "Welcome to the ##var## powered by SMSINDIAHUB. Your OTP for registration is ##var##"
# {brand} -> first ##var## (OTP_BRAND_NAME), {otp} -> second ##var## (generated code).
OTP_SMS_TEMPLATE=Welcome to the {brand} powered by SMSINDIAHUB. Your OTP for registration is {otp}
DEFAULT_TEST_PHONE=9111966732
DEFAULT_TEST_OTP=123456

# ── SMS India Hub (jasti client credentials) ───────────────────────
# true  => send real SMS via SMS India Hub
# false => print OTP to the server terminal (dev/testing)
SMS_INDIA_ENABLED=true
SMS_INDIA_BASE_URL=http://cloud.smsindiahub.in/vendorsms/pushsms.aspx
SMS_INDIA_HUB_USERNAME=SPEEUP
SMS_INDIA_HUB_API_KEY=orkthOe6CEqjIvZaGAVeoA
SMS_INDIA_HUB_SENDER_ID=SMSHUB
SMS_INDIA_HUB_DLT_TEMPLATE_ID=1007801291964877107
